<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>Shop - Page 2</title>
        <link rel="stylesheet" href="css/BROKE.css">
        <link rel="icon" href="images/broke.jpg" type="image/jpeg">
    </head>
    <body>
        <header>
            
            <nav class="navbar">
                <ul>
                    <li><a href="Homepage.html">Homepage</a></li>
                    <li><a href="ABOUT US .html">ABOUT US</a></li>
                    <li><a href="CONTACT.html">CONTACT</a></li>
                    <li><a href="SIGN IN .html">SIGN IN</a></li>
                    <li><a href="Shop.html">Shop</a></li>
                </ul>
            </nav>
        </header>

        <main>
            <img src="images/essentals.jpg" height="250" alt="BROKE banner">

            <div class="products">
                <img src="images/Bvest.jpg" height="250" alt="BROKE vest">
                <img src="images/Vwear.jpg" height="250" alt="Vest">
                <img src="images/Bwear.jpg" height="250" alt="Boxers">
                <img src="images/Swear.jpg" height="250" alt="Socks">
            </div>

            <form id="enquiryForm">
                <label for="product">Product</label>
                <select id="product" name="product">
                    <option>Cap</option>
                    <option>Tracksuit</option>
                    <option>T-Shirt</option>
                    <option>Knit Wear</option>
                    <option>Essentials</option>
                </select>

                <label>Size</label>
                <label><input type="radio" name="size" value="S"> S</label>
                <label><input type="radio" name="size" value="M"> M</label>
                <label><input type="radio" name="size" value="L"> L</label>

                <label for="quantity">Quantity</label>
                <input type="number" id="quantity" name="quantity">

                <button type="submit">Check Availability</button>
            </form>

             <section class="hero">
                <h1>BROKE</h1>
                <p>Being rebellious over conforming to expectations.</p>
                <button>SHOP NOW</button>
            </section>

            <p id="response"></p>
            <div class="pagination">
                <a href="Shop.html">1</a>
                <a href="Shop1.html" class="active">2</a>
                <a href="Shop2.html">3</a>
                <a href="Shop3.html">4</a>
                <a href="Shop4.html">5</a>
            </div>
            </div>
            </div>
        </main>

        <footer>
             <h3>Rate This Product</h3>

       <div class="stars">
         <span class="star" onclick="setRating(1)">★</span>
         <span class="star" onclick="setRating(2)">★</span>
         <span class="star" onclick="setRating(3)">★</span>
         <span class="star" onclick="setRating(4)">★</span>
         <span class="star" onclick="setRating(5)">★</span>
       </div>

<p id="ratingText">Select a rating</p>

